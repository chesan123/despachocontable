---
import "../styles/global.css";
import AOS from "aos";
import "aos/dist/aos.css";
import hero from "../content/hero.json";
import servicios from "../content/servicios.json";
import equipo from "../content/equipo.json";
import nosotros from "../content/nosotros.json";
import ubicacion from "../content/ubicacion.json";
import contacto from "../content/contacto.json";
import tramites from "../content/tramites.json";

const personas = equipo.personas;
if (typeof window !== "undefined") {
	setTimeout(() => {
		AOS.init({
			duration: 1000,
			once: true,
		});
	}, 100);
}
---

<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Despacho Contable</title>
		<script src="https://unpkg.com/lucide@latest"></script>
	</head>

	<body class="bg-[#f8f5f2] text-gray-800">
		<!-- NAVBAR -->
		<nav
			class="w-full fixed top-0 left-0 z-50 bg-white/80 backdrop-blur-md shadow-sm border-b border-[#eee]"
		>
			<div
				class="max-w-6xl mx-auto flex justify-between items-center px-6 py-4"
			>
				<h1 class="font-bold text-[#6b4f3b] text-xl tracking-wide">
					Despacho <span class="text-[#8b6a52]">DAVI</span>
				</h1>

				<!-- BOTÓN MOBILE -->
				<button id="menuBtn" class="md:hidden text-2xl">☰</button>
				<!-- LINKS DESKTOP -->
				<div
					class="hidden md:flex items-center gap-8 font-medium text-gray-700"
				>
					<a
						href="#servicios"
						class="flex items-center gap-2 hover:text-[#6b4f3b]"
					>
						<i data-lucide="briefcase" class="w-4 h-4"></i> Servicios
					</a>
					<a
						href="#nosotros"
						class="flex items-center gap-2 hover:text-[#6b4f3b]"
					>
						<i data-lucide="users" class="w-4 h-4"></i> Nosotros
					</a>
					<a
						href="#contacto"
						class="flex items-center gap-2 hover:text-[#6b4f3b]"
					>
						<i data-lucide="mail" class="w-4 h-4"></i> Contacto
					</a>
				</div>
			</div>

			<!-- MENÚ MOBILE -->
			<div
				id="mobileMenu"
				class="hidden flex flex-col gap-4 p-4 bg-white md:hidden"
			>
				<a href="#servicios" onclick="toggleMenu()">Servicios</a>
				<a href="#nosotros" onclick="toggleMenu()">Nosotros</a>
				<a href="#contacto" onclick="toggleMenu()">Contacto</a>
			</div>
		</nav>

		<!-- HERO -->
		<section
			class="relative min-h-[70vh] md:h-screen flex items-center justify-center text-center pt-20"
		>
			<img
				src={hero.imagen}
				class="absolute w-full h-full object-cover top-0 left-0"
			/>
			<div class="absolute w-full h-full bg-black/50"></div>

			<div class="relative z-10 text-white max-w-2xl px-4">
				<h1 class="text-3xl md:text-5xl font-bold mb-4">
					{hero.titulo}
				</h1>
				<p class="text-base md:text-lg mb-6">{hero.descripcion}</p>
				<a
					href="https://wa.me/5210000000000"
					class="bg-[#6b4f3b] px-6 py-3 rounded-lg shadow hover:bg-[#5a3f2e] transition transform hover:scale-105"
				>
					Contáctanos
				</a>
			</div>
		</section>

		<!-- TRÁMITES -->
		<section class="py-12 md:py-20 bg-[#f1ece8] text-center">
			<h2 class="text-2xl md:text-3xl font-bold mb-10 text-[#6b4f3b]">
				Trámites e Información
			</h2>

			<div class="max-w-4xl mx-auto space-y-6 px-4">
				{
					tramites.items.map((t) => (
						<details class="bg-white p-6 rounded-lg shadow hover:shadow-xl transition">
							<summary class="font-bold text-lg cursor-pointer">
								{t.titulo}
							</summary>

							<p class="mt-4 text-gray-700">{t.descripcion}</p>
						</details>
					))
				}
			</div>
		</section>

		<!-- SERVICIOS -->
		<section id="servicios" class="py-12 md:py-20 bg-white text-center">
			<h2 class="text-2xl md:text-3xl font-bold mb-10 text-[#6b4f3b]">
				Nuestros Servicios
			</h2>

			<div
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 max-w-6xl mx-auto px-4"
			>
				{
					servicios.items.map((s) => (
						<div class="p-6 rounded-xl shadow hover:shadow-2xl transition transform hover:-translate-y-2 text-center">
							<img src={s.imagen} class="w-16 mx-auto mb-4" />
							<h3 class="font-bold text-xl mb-2">{s.titulo}</h3>
							<p class="text-gray-600">{s.descripcion}</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- NOSOTROS -->
		<section id="nosotros" class="py-12 md:py-20 bg-[#f8f5f2]">
			<div
				class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-center px-4"
			>
				<img
					src={nosotros.imagen}
					class="rounded-xl shadow-lg w-full max-w-md mx-auto"
				/>

				<div>
					<h2
						class="text-2xl md:text-3xl font-bold mb-4 text-[#6b4f3b]"
					>
						{nosotros.titulo}
					</h2>
					<p class="text-gray-600 mb-4">{nosotros.descripcion}</p>

					<ul class="space-y-2 text-gray-700">
						{
							nosotros.caracteristicas.map((c) => (
								<li>✔ {c.texto}</li>
							))
						}
					</ul>
				</div>
			</div>
		</section>

		<!-- EQUIPO -->
		<section class="py-12 md:py-20 bg-white text-center">
			<h2 class="text-2xl md:text-3xl font-bold mb-10 text-[#6b4f3b]">
				Nuestro equipo
			</h2>

			<div
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 max-w-6xl mx-auto px-4"
			>
				{
					personas.map((e) => (
						<div class="bg-[#f1ece8] p-6 rounded-xl shadow hover:shadow-2xl transition transform hover:-translate-y-2">
							<img
								src={e.imagen}
								class="w-24 h-24 md:w-32 md:h-32 mx-auto rounded-full mb-4 border-4 border-white shadow"
							/>
							<h3 class="font-bold text-lg">{e.nombre}</h3>
							<p class="text-sm text-gray-600">{e.puesto}</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- UBICACIÓN -->
		<section class="py-12 md:py-20 bg-[#f8f5f2] text-center">
			<h2 class="text-2xl md:text-3xl font-bold mb-10 text-[#6b4f3b]">
				{ubicacion.titulo}
			</h2>

			<div
				class="max-w-6xl mx-auto px-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6"
			>
				{
					ubicacion.ubicaciones.map((item) => (
						<div class="bg-white rounded-xl shadow-lg p-4">
							<h3 class="text-lg font-semibold mb-2 text-[#6b4f3b]">
								{item.titulo}
							</h3>
							<iframe
								src={item.mapa}
								width="100%"
								height="250"
								class="rounded-lg border"
								loading="lazy"
							/>
							<p class="mt-3 text-gray-600 text-sm">
								{item.direccion}
							</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- CONTACTO -->
		<section id="contacto" class="py-12 md:py-20 text-center bg-white">
			<h2 class="text-2xl md:text-3xl font-bold mb-6 text-[#6b4f3b]">
				{contacto.titulo}
			</h2>

			<p class="mb-6 text-gray-600 px-4">{contacto.descripcion}</p>

			<div
				class="flex flex-col md:flex-row justify-center items-center gap-4"
			>
				<a
					href={`https://wa.me/${contacto.whatsapp}`}
					class="w-48 md:w-auto border-2 border-[#6b4f3b] text-[#6b4f3b] px-6 py-3 rounded-lg hover:bg-[#6b4f3b] hover:text-white transition transform hover:scale-105"
				>
					WhatsApp
				</a>

				<a
					href={`mailto:${contacto.correo}`}
					class="w-48 md:w-auto border-2 border-[#6b4f3b] text-[#6b4f3b] px-6 py-3 rounded-lg hover:bg-[#6b4f3b] hover:text-white transition transform hover:scale-105"
				>
					Enviar correo
				</a>
			</div>

			<p class="mt-6 text-gray-500 px-4">
				o escríbenos a: <span class="font-semibold break-all"
					>{contacto.correoVisible}</span
				>
			</p>
		</section>

		<footer class="bg-[#6b4f3b] text-white text-center py-4">
			<p>&copy; 2026 Despacho Contable DAVI</p>
			<a href="/aviso-privacidad" class="text-sm underline"
				>Aviso de privacidad</a
			>
		</footer>

		<script>
			declare const lucide: any;
			lucide.createIcons();
		</script>

		<script is:inline>
			const btn = document.getElementById("menuBtn");
			const menu = document.getElementById("mobileMenu");

			btn?.addEventListener("click", () => {
				menu?.classList.toggle("hidden");
			});

			document.querySelectorAll("#mobileMenu a").forEach((link) => {
				link.addEventListener("click", () => {
					menu?.classList.add("hidden");
				});
			});
		</script>
	</body>
</html>
